# Local proxy environment — copy to proxy/.env and fill in values.
# Run scripts/setup-env.sh to populate this automatically from CDK stack outputs.
# NEVER commit proxy/.env — it contains real endpoint URLs and your AWS account ID.

AWS_PROFILE=default
AWS_REGION=eu-west-1
LINIONS_GENERATE_URL=https://<generate-function-url>.lambda-url.<region>.on.aws/
LINIONS_STATUS_URL=https://<status-function-url>.lambda-url.<region>.on.aws/
LINIONS_PUBLISH_URL=https://<publish-function-url>.lambda-url.<region>.on.aws/
CLOUDFRONT_DOMAIN=https://<cloudfront-id>.cloudfront.net
EPISODES_BUCKET=linions-episodes-<your-account-id>
